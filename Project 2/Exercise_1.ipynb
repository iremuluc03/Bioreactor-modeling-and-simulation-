import matplotlib.pyplot as plt
import numpy as np

#PROJECT 2 : ENZYME KINETICS AND MICROBIAL GROWTH
#EXERCISE 1
## i'll be writing my own commentary on the creation of the code with double #, delete it once the issue is addressed

#Growth data
#Substrate concentration S [mM]
S1 = [0.2,0.4,0.8,1,2,4]
#Reaction rate v without inhibitor (0), with inhibitor A (A) or with inhibitor B (B) [mM/min]
v10 = [5,7.5,10,10.7,12.5,13.6]
v1A = [3,5,7.5,8.3,10.7,12.5]
v1B = [2,3,4,4.3,5,5.5]

#1.A. Linweaver-Burke plot of the data
IS1 = np.divide(1,S1)
Iv10 = np.divide(1,v10)
Iv1A = np.divide(1,v1A)
Iv1B = np.divide(1,v1B)
plt.plot(IS1,Iv10,color='green',label='Without inhibitor')
plt.plot(IS1,Iv1A,color='orange',label='With nhibitor A')
plt.plot(IS1,Iv1B,color='blue',label='With inhibitor B')
plt.title("Lineweaver-Burker plot of an enzyme's reaction rate with or without added inhibitors") ##do we really need that?
plt.xlabel('1/v [mM/min]')
plt.ylabel('1/S [1/mM]')
plt.legend(loc='upper left')
#Limit of the X range = limits of IS1
plt.xlim(0.25,5) ##maybe change arguments in here to make the previous comment clearer or remove it if you feel it's unnecessary
plt.show() ##need to increase dpi
plt.clf()


#1.B. Determining Km and vmax values from the Lineweaver-Burke plot
##Replace Km and vmax by their written names here ^^^
#vmax = graph intercept
#Km/vmax = graph slope
def get1B(v,s):
    vmax = np.polyfit(s,v,1)[1]
    km = np.polyfit(s,v,1)[0]*vmax
    return vmax,km
vmax10, Km10 = get1B(Iv10,IS1) ##add units?
print('Without inhibition, vmax =',vmax10,' and Km =',Km10)
vmax1A, Km1A = get1B(Iv1A,IS1)
print('With inhibitor A added, vmax =',vmax1A,' and Km =',Km1A)
vmax1B, Km1B = get1B(Iv1B,IS1)
print('With inhibitor B added, vmax =',vmax1B,' and Km =',Km1B)

